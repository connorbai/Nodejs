WITH prdct_ctgry AS (SELECT prdct.star_id star_prdct_id,TO_CHAR(prdct.mrkt_start_dt, 'YYYYMM')::INTEGER prdct_mrkt_start_dt,TO_CHAR(prdct.mrkt_end_dt, 'YYYYMM')::INTEGER prdct_mrkt_end_dt,ctgry.star_id star_ctgry_id,TO_CHAR(ctgry.mrkt_star_dt, 'YYYYMM')::INTEGER ctgry_mrkt_start_dt,TO_CHAR(ctgry.mrkt_end_dt, 'YYYYMM')::INTEGER ctgry_mrkt_end_dtFROM cmd_owner.m_prdct prdctINNER JOIN 
cmd_owner.m_prdct_ctgry ctgry ON ctgry.id = prdct.prdct_ctgry_idWHERE prdct.stts_ind = 1 AND prdct.isdeleted = false AND ctgry.stts_ind = 1 AND ctgry.isdeleted = false)SELECT thc.group_key,thc.hco_id,thc.type,thc.prdct_ctgry_id,pc.star_prdct_idFROM cmd_owner.m_rltn_trtry_hco_ctgry thcINNER JOIN prdct_ctgry pc ON pc.star_ctgry_id = thc.prdct_ctgry_id AND thc.year_month BETWEEN prdct_mrkt_start_dt AND prdct_mrkt_end_dt AND thc.year_month BETWEEN ctgry_mrkt_start_dt AND ctgry_mrkt_end_dtWHERE thc.year_month IN (202304) AND bu_id IN (20000003) AND thc.stts_ind=1 AND thc.isdeleted=False