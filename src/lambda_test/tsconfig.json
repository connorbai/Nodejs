{
    "compilerOptions": {
        "target": "ES6",
        "module": "commonjs",
        "outDir": "dist",
        "removeComments": true,
        "strict": true,
        "strictNullChecks": false,
        "noImplicitAny": false,
        "strictPropertyInitialization": false,
        "baseUrl": ".",
        "esModuleInterop": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "sourceMap": false
    },
    "include": ["."],
    "exclude": ["node_modules", "dist", "log"],
    "ts-node":{
        "transpileOnly": true
    }
}